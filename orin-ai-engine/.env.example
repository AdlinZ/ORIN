# ORIN AI Engine local smoke defaults
# Copy to orin-ai-engine/.env before running the MQ worker locally.

# Java backend used by workflow callbacks
ORIN_BACKEND_URL=http://localhost:8080

# RabbitMQ profile from docker/local-infra/.env.example
ORIN_RABBITMQ_URL=amqp://orin:ChangeMeRabbitMQ123!@localhost:5672//orin

# Collaboration queue topology
ORIN_COLLAB_QUEUE_NAME=collaboration-task-queue
ORIN_COLLAB_RESULT_QUEUE_NAME=collaboration-task-result-queue
ORIN_COLLAB_REPLY_EXCHANGE_NAME=collaboration-reply-exchange
ORIN_COLLAB_REPLY_ROUTING_KEY=collaboration.task.result
