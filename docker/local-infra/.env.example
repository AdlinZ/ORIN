# Base stack
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMeGrafana123!
GRAFANA_ROOT_URL=http://localhost:3000
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8081
NVIDIA_NODE_EXPORTER_PORT=9835

# Internal MinIO used by Milvus standalone
MILVUS_MINIO_ACCESS_KEY=milvusadmin
MILVUS_MINIO_SECRET_KEY=MilvusMinioChangeMe123!

# Optional RabbitMQ profile
RABBITMQ_DEFAULT_USER=orin
RABBITMQ_DEFAULT_PASS=ChangeMeRabbitMQ123!
RABBITMQ_DEFAULT_VHOST=/orin
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Optional Neo4j profile
NEO4J_AUTH=neo4j/ChangeMeNeo4j123!
NEO4J_HEAP_INIT=512m
NEO4J_HEAP_MAX=2g
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Optional standalone object storage profile
MINIO_ROOT_USER=orinminio
MINIO_ROOT_PASSWORD=ChangeMeMinio123!
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Optional Langfuse profile
LANGFUSE_PUBLIC_URL=http://localhost:3001
LANGFUSE_PORT=3001
LANGFUSE_NEXTAUTH_SECRET=ChangeThisNextAuthSecretAtLeast32Chars
LANGFUSE_SALT=ChangeThisSaltAtLeast32CharsLong
LANGFUSE_ENCRYPTION_KEY=ChangeThisEncryptionKeyAtLeast32Chars
LANGFUSE_POSTGRES_DB=langfuse
LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_PASSWORD=ChangeMeLangfusePg123!
LANGFUSE_CLICKHOUSE_DB=default
LANGFUSE_CLICKHOUSE_USER=default
LANGFUSE_CLICKHOUSE_PASSWORD=
LANGFUSE_CLICKHOUSE_HTTP_PORT=8123
LANGFUSE_CLICKHOUSE_NATIVE_PORT=9000
LANGFUSE_REDIS_PASSWORD=ChangeMeLangfuseRedis123!
LANGFUSE_S3_BUCKET=langfuse
LANGFUSE_S3_REGION=us-east-1
LANGFUSE_S3_ACCESS_KEY=langfuse
LANGFUSE_S3_SECRET_KEY=ChangeMeLangfuseS3123!
