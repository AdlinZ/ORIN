# 本文件可提交至代码库；真实密钥写在 .env，且 .env 必须在 .gitignore 中

# ------------------------------
# Service ports exposed on host
# ------------------------------
FRONTEND_PORT=5173
BACKEND_PORT=8080
AI_ENGINE_PORT=8000
BACKEND_DEBUG_PORT=5005

# ------------------------------
# MySQL bootstrap
# ------------------------------
MYSQL_ROOT_PASSWORD=replace_with_local_root_password
MYSQL_DATABASE=orindb
MYSQL_USER=orin_user
MYSQL_PASSWORD=replace_with_local_db_password

# ------------------------------
# Redis
# ------------------------------
REDIS_PASSWORD=replace_with_local_redis_password

# ------------------------------
# RabbitMQ
# ------------------------------
RABBITMQ_USERNAME=orin
RABBITMQ_PASSWORD=replace_with_local_rabbitmq_password
RABBITMQ_VHOST=/orin
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Optional: enables AI Engine collaboration MQ worker for Workflow subtask smoke.
# Keep disabled for quickstart unless explicitly validating collaboration Workflow subtasks.
ORIN_RABBITMQ_URL=amqp://orin:replace_with_local_rabbitmq_password@rabbitmq:5672/%2Forin
ORIN_MQ_WORKER_DISABLED=true
ORIN_MQ_WORKER_AUTO_START=false
COLLAB_LISTENERS_AUTO_STARTUP=false
# JWT bearer token used by the AI Engine worker when calling protected backend APIs.
# JWTs expire; refresh before running ORIN_BUSINESS_SMOKE_WORKFLOW_SUBTASK=1.
ORIN_BACKEND_AUTHORIZATION=

# ------------------------------
# Backend runtime
# ------------------------------
SPRING_PROFILES_ACTIVE=dev
ORIN_DEFAULT_ADMIN_PASSWORD=admin123
JWT_SECRET=replace_with_64_bytes_random_secret_generated_by_openssl_rand_base64_64
JWT_EXPIRATION=86400000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173
TZ=Asia/Shanghai

# ------------------------------
# Optional model provider keys
# Leave empty for infrastructure-only smoke tests.
# ------------------------------
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_VLM_MODEL=Qwen/Qwen2-VL-72B-Instruct

# ------------------------------
# Optional dependencies managed by docker/local-infra
# Root compose does not start these services.
# ------------------------------
MILVUS_HOST=localhost
MILVUS_PORT=19530
LANGFUSE_ENABLED=false
COLLAB_MODE=JAVA_NATIVE

# ------------------------------
# OpenTelemetry / Jaeger（Phase 2 小刀 5c）
# 启用后 AI Engine + 后端 Java 端都把 span 上报到 jaeger:16686，
# 跨进程 trace_id 串联（HTTP → 后端 → AI Engine → MQ → engine 内部 → outbound
# → 后端）可在 Jaeger UI 看到完整 trace tree。
#
# ORIN_TRACING_ENABLED=true 启用；false 时后端 OpenTelemetryConfig 跳过
# TracerProvider 初始化，AI Engine 走 OTEL_SDK_DISABLED=no-op 路径。
# AI Engine 端 OTEL 字段（5a/5b 引入）走 opentelemetry SDK 1.42.x 标准 env，
# 不依赖 ORIN_ 前缀。
# ------------------------------
ORIN_TRACING_ENABLED=true
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318
