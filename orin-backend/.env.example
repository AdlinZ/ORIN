# ==============================================
# ORIN 后端环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ==============================================

# ==============================================
# 数据库配置 (必需)
# ==============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=orindb
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# ==============================================
# Redis 配置 (必需)
# ==============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==============================================
# JWT 配置 (必需 - 生产环境必须修改)
# ==============================================
# 使用 openssl rand -base64 64 生成安全的随机密钥
JWT_SECRET=your_256_bit_random_secret_key_here
JWT_EXPIRATION=86400000

# ==============================================
# 数据加密配置 (建议 - 用于管理员密钥受控回显)
# ==============================================
# 使用 openssl rand -base64 32 生成
ENCRYPTION_KEY=your_encryption_key_here

# ==============================================
# SiliconFlow API 配置 (必需 - 用于 LLM 和 Embedding)
# ==============================================
SILICONFLOW_API_KEY=sk-your_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_VLM_MODEL=Qwen/Qwen2-VL-72B-Instruct

# ==============================================
# Milvus 向量数据库配置 (必需 - 用于知识库向量检索)
# ==============================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TOKEN=

# ==============================================
# AI 引擎配置 (必需 - Python FastAPI 服务地址)
# ==============================================
ORIN_AI_ENGINE_URL=http://localhost:8000

# ==============================================
# RAGFlow 配置 (可选)
# ==============================================
RAGFLOW_DEFAULT_ENDPOINT=http://localhost:9380/v1
RAGFLOW_DEFAULT_API_KEY=
RAGFLOW_API_TIMEOUT=60000

# ==============================================
# Dify 配置 (可选)
# ==============================================
DIFY_DEFAULT_ENDPOINT=http://localhost:3000/v1
DIFY_DEFAULT_API_KEY=
DIFY_API_TIMEOUT=120000
DIFY_HEALTH_CHECK_INTERVAL=60000

# ==============================================
# Jina Reader 配置 (可选 - 用于网页转 Markdown)
# ==============================================
JINA_READER_ENABLED=true
JINA_READER_API_KEY=

# ==============================================
# RabbitMQ 配置 (可选 - 用于异步任务队列)
# ==============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
# 与 docker/local-infra/.env.example 的 queue profile 默认值保持一致
RABBITMQ_USERNAME=orin
RABBITMQ_PASSWORD=ChangeMeRabbitMQ123!
RABBITMQ_VHOST=/orin

# ==============================================
# 协作模块 MQ 配置 (可选 - 用于 LangGraph + MQ 编舞)
# ==============================================
# JAVA_NATIVE = 使用 Java 内存编舞（默认）
# LANGGRAPH_MQ = 使用 LangGraph + RabbitMQ 编舞
COLLAB_MODE=JAVA_NATIVE
COLLAB_MQ_FOR_PARALLEL=true
COLLAB_MQ_FOR_SEQUENTIAL=false
COLLAB_MQ_FOR_CONSENSUS=false

# ==============================================
# Langfuse 配置 (可选 - LLM 可观测性)
# ==============================================
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ==============================================
# 限流配置
# ==============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ==============================================
# CORS 配置 (必需 - 生产环境)
# ==============================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com

# ==============================================
# 服务端口配置
# ==============================================
SERVER_PORT=8080

# ==============================================
# 应用配置
# ==============================================
SPRING_PROFILES_ACTIVE=dev

# ==============================================
# Ollama 本地 LLM 配置 (可选 - 用于本地模型推理)
# ==============================================
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_API_KEY=ollama
# OLLAMA_MODEL=llama3

# ==============================================
# Neo4j 图数据库配置 (可选 - 用于知识图谱)
# ==============================================
# 对于外部托管 Neo4j，推荐直接配置 URI（例如 neo4j+s://xxx.databases.neo4j.io）
NEO4J_URI=
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT_MS=60000

# ==============================================
# SMTP 邮件配置 (可选 - 用于邮件通知)
# ==============================================
# SPRING_MAIL_HOST=smtp.qq.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-email@qq.com
# SPRING_MAIL_PASSWORD=your-auth-code
