# ==============================================
# ORIN 后端环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ==============================================

# ==============================================
# 数据库配置 (必需)
# ==============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=orindb
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# ==============================================
# Redis 配置 (必需)
# ==============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==============================================
# JWT 配置 (必需 - 生产环境必须修改)
# ==============================================
# 使用 openssl rand -base64 64 生成安全的随机密钥
JWT_SECRET=your_256_bit_random_secret_key_here
JWT_EXPIRATION=86400000

# ==============================================
# SiliconFlow API 配置 (必需)
# ==============================================
SILICONFLOW_API_KEY=sk-your_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_VLM_MODEL=Qwen/Qwen2-VL-72B-Instruct

# ==============================================
# Milvus 向量数据库配置
# ==============================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TOKEN=

# ==============================================
# RAGFlow 配置 (可选)
# ==============================================
RAGFLOW_DEFAULT_ENDPOINT=http://localhost:9380/v1
RAGFLOW_DEFAULT_API_KEY=
RAGFLOW_API_TIMEOUT=60000

# ==============================================
# Dify 配置 (可选)
# ==============================================
DIFY_DEFAULT_ENDPOINT=http://localhost:3000/v1
DIFY_DEFAULT_API_KEY=
DIFY_API_TIMEOUT=120000
DIFY_HEALTH_CHECK_INTERVAL=60000

# ==============================================
# Jina Reader 配置 (可选 - 用于网页转 Markdown)
# ==============================================
JINA_READER_ENABLED=true
JINA_READER_API_KEY=

# ==============================================
# RabbitMQ 配置 (可选)
# ==============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ==============================================
# Langfuse 配置 (可选 - LLM 可观测性)
# ==============================================
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ==============================================
# 限流配置
# ==============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ==============================================
# CORS 配置 (必需 - 生产环境)
# ==============================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com

# ==============================================
# 服务端口配置
# ==============================================
SERVER_PORT=8080

# ==============================================
# 应用配置
# ==============================================
SPRING_PROFILES_ACTIVE=dev
